class Solution:
    def mergeAlternately(self, word1: str, word2: str) -> str:
        i=0 
        j=0
        merged = []
        if(len(word1)==len(word2)):
            while(i<len(word1)):
                merged.append(word1[i])
                merged.append(word2[i])
                i=i+1
        elif(len(word1)<len(word2)):
            while(i<len(word1)):
                merged.append(word1[i])
                merged.append(word2[i])
                i=i+1
            merged.append(word2[i:])
        else:
            while(i<len(word2)):
                merged.append(word1[i])
                merged.append(word2[i])
                i=i+1
            merged.append(word1[i:])

        return "".join(merged)

